{
  "name": "zk-tutorial",
  "version": "1.0.0",
  "description": "Learn Circom and ZK proofs with hands-on examples",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "compile:age": "circom circuits/age_verifier.circom --r1cs --wasm --sym -o build",
    "compile:commitment": "circom circuits/commitment.circom --r1cs --wasm --sym -o build",
    "compile:merkle": "circom circuits/merkle_proof.circom --r1cs --wasm --sym -o build",
    "compile:transfer": "circom circuits/private_transfer.circom --r1cs --wasm --sym -o build",
    "setup": "node scripts/setup.js",
    "prove": "node scripts/prove.js"
  },
  "keywords": ["circom", "zk-snarks", "zero-knowledge", "tutorial"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "ffjavascript": "^0.2.60",
    "snarkjs": "^0.7.3"
  }
}